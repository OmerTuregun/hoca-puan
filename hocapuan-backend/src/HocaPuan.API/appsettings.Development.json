{
  "App": {
    "FrontendUrl": "http://localhost:5173"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173",
      "http://localhost:3000",
      "http://localhost:4173"
    ]
  },
  "AuthCookie": {
    "Secure": false,
    "SameSite": "Strict"
  },
  "RateLimiting": {
    "Auth": { "PermitLimit": 100, "WindowMinutes": 5 },
    "CommentWrite": { "PermitLimit": 30, "WindowMinutes": 1 },
    "ReportWrite": { "PermitLimit": 30, "WindowMinutes": 1 },
    "Global": { "PermitLimit": 1000, "WindowMinutes": 1 }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  }
}
