# HocaPuan — ortam değişkenleri
# Kullanım: bu dosyayı kopyalayın →  cp .env.example .env  (veya Windows'ta kopyala-yapıştır)
# .env asla git'e commit edilmez (.gitignore)

# ─── PostgreSQL ───────────────────────────────────────────────
DB_NAME=hocapuan
DB_USER=hocapuan_user
DB_PASSWORD=degistir_guclu_sifre
DB_PORT=5433
# dotnet run (Docker dışı) için veritabanı hostu
DB_HOST=localhost

# ─── pgAdmin ──────────────────────────────────────────────────
PGADMIN_EMAIL=admin@hocapuan.com
PGADMIN_PASSWORD=degistir_guclu_sifre
PGADMIN_PORT=5051

# ─── API ──────────────────────────────────────────────────────
API_PORT=5001
ASPNETCORE_ENVIRONMENT=Development

# ─── JWT (gizli — en az 32 karakter) ─────────────────────────
JWT_SECRET=degistir_uzun_rastgele_anahtar
JWT_ISSUER=HocaPuanAPI
JWT_AUDIENCE=HocaPuanClient
JWT_EXPIRATION_HOURS=24

# ─── Uygulama URL ─────────────────────────────────────────────
APP_FRONTEND_URL=http://localhost:5173

# ─── E-posta / SMTP (Mailtrap veya production SMTP) ───────────
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USERNAME=mailtrap_kullanici_adiniz
EMAIL_PASSWORD=mailtrap_sifreniz
EMAIL_FROM=noreply@hocapuan.com

# ─── Frontend (Docker) ────────────────────────────────────────
FRONTEND_PORT=5173
