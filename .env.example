# HocaPuan — ortam değişkenleri referansı
# Geliştirme:  cp .env.example .env.development
# Production:   cp .env.example .env.production
#
# .env, .env.development ve .env.production git'e commit edilmez (.gitignore)

# ═══════════════════════════════════════════════════════════════
# ORTAK
# ═══════════════════════════════════════════════════════════════

# ─── PostgreSQL ───────────────────────────────────────────────
DB_NAME=hocapuan
DB_USER=hocapuan_user
DB_PASSWORD=
DB_PORT=5433
# dotnet run (Docker dışı) için veritabanı hostu
DB_HOST=localhost

# ─── API ──────────────────────────────────────────────────────
API_PORT=5001
ASPNETCORE_ENVIRONMENT=

# ─── JWT (gizli — en az 32 karakter) ─────────────────────────
JWT_SECRET=
JWT_ISSUER=HocaPuanAPI
JWT_AUDIENCE=HocaPuanClient
JWT_EXPIRATION_HOURS=24

# ─── Uygulama URL (e-posta linkleri) ──────────────────────────
APP_FRONTEND_URL=

# ─── CORS (Production — tarayıcının eriştiği frontend origin) ─
ALLOWED_ORIGIN=

# ─── Cookie / HTTPS ───────────────────────────────────────────
# Development: USE_HTTPS=false, COOKIE_SECURE=false
# Production HTTP: USE_HTTPS=false, COOKIE_SECURE=false, AUTH_COOKIE_SAMESITE=Lax
# Production HTTPS: USE_HTTPS=true, COOKIE_SECURE=true, AUTH_COOKIE_SAMESITE=Strict
USE_HTTPS=
COOKIE_SECURE=
AUTH_COOKIE_SAMESITE=

# ─── E-posta / SMTP ───────────────────────────────────────────
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@hocapuan.com

# ─── Frontend (Docker host portu) ─────────────────────────────
FRONTEND_PORT=

# ═══════════════════════════════════════════════════════════════
# YALNIZCA GELİŞTİRME (docker-compose.dev.yml)
# ═══════════════════════════════════════════════════════════════

# ─── pgAdmin ──────────────────────────────────────────────────
PGADMIN_EMAIL=admin@hocapuan.com
PGADMIN_PASSWORD=
PGADMIN_PORT=5051
