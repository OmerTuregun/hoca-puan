# HocaPuan — ortam değişkenleri referansı
# Geliştirme:  cp .env.example .env.development
# Production:   cp .env.example .env.production
#
# .env, .env.development ve .env.production git'e commit edilmez (.gitignore)

# ═══════════════════════════════════════════════════════════════
# ORTAK
# ═══════════════════════════════════════════════════════════════

# ─── PostgreSQL ───────────────────────────────────────────────
DB_NAME=hocapuan
DB_USER=hocapuan_user
DB_PASSWORD=
DB_PORT=
# dotnet run (Docker dışı) için veritabanı hostu
DB_HOST=localhost

# ─── API ──────────────────────────────────────────────────────
API_PORT=
ASPNETCORE_ENVIRONMENT=

# ─── JWT (gizli — en az 32 karakter) ─────────────────────────
JWT_SECRET=
JWT_ISSUER=HocaPuanAPI
JWT_AUDIENCE=HocaPuanClient
JWT_EXPIRATION_HOURS=24

# ─── Uygulama URL (e-posta linkleri) ──────────────────────────
APP_FRONTEND_URL=

# ─── CORS (Production — tarayıcının eriştiği frontend origin) ─
ALLOWED_ORIGIN=

# ─── Cookie / HTTPS ───────────────────────────────────────────
# Development: USE_HTTPS=false (veya tanımsız)
# Production HTTP: USE_HTTPS=false  → Secure=false, SameSite=Lax
# Production HTTPS: USE_HTTPS=true   → Secure=true, SameSite=Strict (tek değişken yeterli)
# İsteğe bağlı override: COOKIE_SECURE, AUTH_COOKIE_SAMESITE
USE_HTTPS=
COOKIE_SECURE=
AUTH_COOKIE_SAMESITE=

# ─── E-posta / SMTP ───────────────────────────────────────────
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@hocapuan.com

# ─── Frontend (Docker host portu) ─────────────────────────────
FRONTEND_PORT=

# ─── Yedekleme (Google Drive / rclone) ────────────────────────
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/root/secrets/hocapuan-backup-key.json
GOOGLE_DRIVE_BACKUP_FOLDER_ID=
RCLONE_BACKUP_PATH=Ömer Bireysel/Hocanı Yorumla/HocaPuan-Backups
# BACKUP_ALERT_EMAIL=admin@example.com

# ═══════════════════════════════════════════════════════════════
# GELİŞTİRME ÖRNEK DEĞERLERİ (docker-compose.dev.yml)
# API_PORT=5001, FRONTEND_PORT=5173, DB_PORT=5433
# ASPNETCORE_ENVIRONMENT=Development
# ═══════════════════════════════════════════════════════════════

# ─── pgAdmin (yalnızca dev) ───────────────────────────────────
PGADMIN_EMAIL=admin@hocapuan.com
PGADMIN_PASSWORD=
PGADMIN_PORT=5051

# ═══════════════════════════════════════════════════════════════
# PRODUCTION ÖRNEK DEĞERLERİ (docker-compose.prod.yml)
# API_PORT=5011, FRONTEND_PORT=8089, DB_PORT=5435
# ASPNETCORE_ENVIRONMENT=Production
# DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# JWT_SECRET=CHANGE_ME_GENERATE_STRONG_SECRET
# USE_HTTPS=false
# ALLOWED_ORIGIN=http://SUNUCU_IP:8089
# APP_FRONTEND_URL=http://SUNUCU_IP:8089
# ═══════════════════════════════════════════════════════════════
